<Window x:Class="drivenvms.CreateVmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Створення нової ВМ" Height="420" Width="420"
        WindowStartupLocation="CenterOwner" Background="#F3F3F3" FontFamily="Segoe UI" ResizeMode="NoResize">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Margin="0,0,0,15">
			<TextBlock Text="Назва віртуальної машини" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,6"/>
			<TextBox x:Name="VmNameInput" Height="32" Padding="8,5" BorderThickness="1" BorderBrush="#CCCCCC" Background="White"/>
		</StackPanel>

		<StackPanel Grid.Row="1" Margin="0,0,0,15">
			<TextBlock Text="Тип операційної системи" FontWeight="SemiBold" FontSize="13" Foreground="#333333" Margin="0,0,0,6"/>
			<ComboBox x:Name="OsTypeCombo" Height="32" Padding="8,5">
				<ComboBoxItem Content="Ubuntu_64" IsSelected="True"/>
				<ComboBoxItem Content="Windows10_64"/>
				<ComboBoxItem Content="Debian_64"/>
				<ComboBoxItem Content="Linux26_64"/>
			</ComboBox>
		</StackPanel>

        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="15" Margin="0,5,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.05" ShadowDepth="1"/>
            </Border.Effect>
            <StackPanel>
                <Grid Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Оперативна пам'ять: " FontWeight="SemiBold" FontSize="13" Foreground="#202020"/>
                        <TextBlock Text="{Binding ElementName=RamSlider, Path=Value}" FontWeight="Bold" FontSize="13" Foreground="#0078D4"/>
                    </StackPanel>
                    <TextBlock Text="MB" Foreground="#888888" HorizontalAlignment="Right" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="RamSlider" Minimum="512" Maximum="8192" Value="1024" TickFrequency="512" IsSnapToTickEnabled="True" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Кількість ядер CPU: " FontWeight="SemiBold" FontSize="13" Foreground="#202020"/>
                        <TextBlock Text="{Binding ElementName=CpuSlider, Path=Value}" FontWeight="Bold" FontSize="13" Foreground="#0078D4"/>
                    </StackPanel>
                </Grid>
                <Slider x:Name="CpuSlider" Minimum="1" Maximum="4" Value="1" TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
			<Button x:Name="CancelBtn" Content="Скасувати" Width="100" Height="35" Margin="0,0,10,0" Background="#E1E1E1" FontWeight="SemiBold" Click="CancelBtn_Click">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}" CornerRadius="4">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</Button.Style>
			</Button>
			<Button x:Name="CreateBtn" Content="Створити" Width="120" Height="35" Background="#0078D4" Foreground="White" FontWeight="SemiBold" Click="CreateBtn_Click">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}" CornerRadius="4">
										<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</Button.Style>
			</Button>
		</StackPanel>
	</Grid>
</Window>