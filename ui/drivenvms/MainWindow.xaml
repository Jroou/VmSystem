<Window x:Class="drivenvms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DrivenVMS — Virtual Machine Manager" Height="520" Width="920"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5" FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Padding="15,10" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="Host System Status" FontWeight="Bold" FontSize="13" Foreground="#333333" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock x:Name="SystemStatsText" FontSize="12" Foreground="#555555" HorizontalAlignment="Right" VerticalAlignment="Center" Text="Reading WinAPI core metrics..."/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="VmsDataGrid" Grid.Column="0" AutoGenerateColumns="False" 
                      IsReadOnly="True" SelectionMode="Single" Background="White" 
                      BorderBrush="#DDDDDD" BorderThickness="1" RowHeight="32" FontSize="12" Margin="0,0,15,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Virtual Machine Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding State}" Width="100"/>
                    <DataGridTextColumn Header="System UUID" Binding="{Binding Uuid}" Width="240"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Process Manager (DLL)" FontWeight="Bold" FontSize="12" Foreground="#333333" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ProcessAnalyticsText" Text="Gathering background metrics..." FontSize="11" FontFamily="Consolas" Foreground="#444444" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Button x:Name="RefreshBtn" Content="Refresh Data" HorizontalAlignment="Left" Width="140" Height="34" Click="RefreshBtn_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="StartBtn" Content="Start" Width="100" Height="34" Margin="0,0,10,0" Click="StartBtn_Click"/>
                <Button x:Name="StopBtn" Content="Stop" Width="100" Height="34" Margin="0,0,10,0" Click="StopBtn_Click"/>
                <Button x:Name="CreateBtn" Content="Create VM" Width="120" Height="34" Click="CreateBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>