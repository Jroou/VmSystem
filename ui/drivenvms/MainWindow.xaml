<Window x:Class="drivenvms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DrivenVMS - Менеджер Віртуальних Машин" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontWeight="Bold" FontSize="16" Margin="0,0,10,0" Text="Хост-система:"/>
                <TextBlock x:Name="SystemStatsText" FontSize="14" VerticalAlignment="Center" Text="Завантаження даних..."/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="VmsDataGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column"
                  Background="White" RowHeight="30" FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва ВМ" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding State}" Width="150"/>
                <DataGridTextColumn Header="UUID" Binding="{Binding Uuid}" Width="250"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RefreshBtn" Content="Оновити список" Width="120" Height="35" Margin="0,0,10,0" Click="RefreshBtn_Click"/>
            <Button x:Name="StartBtn" Content="Запустити" Width="100" Height="35" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" Click="StartBtn_Click"/>
            <Button x:Name="StopBtn" Content="Зупинити" Width="100" Height="35" Margin="0,0,10,0" Background="#F44336" Foreground="White" Click="StopBtn_Click"/>
            <Button x:Name="CreateBtn" Content="Створити нову" Width="120" Height="35" Background="#2196F3" Foreground="White" Click="CreateBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>